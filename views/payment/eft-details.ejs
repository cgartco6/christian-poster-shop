<div class="container">
  <h1>Direct EFT Payment (FNB)</h1>
  <div style="background:#f8f9fa; padding:2rem; border-radius:10px;">
    <p><strong>Bank:</strong> FNB</p>
    <p><strong>Account Name:</strong> <%= process.env.FNB_ACCOUNT_NAME || "Christian Poster Shop CC" %></p>
    <p><strong>Account Number:</strong> <%= process.env.FNB_ACCOUNT_NUMBER %></p>
    <p><strong>Branch Code:</strong> <%= process.env.FNB_BRANCH_CODE %></p>
    <p><strong>Reference:</strong> <code><%= order.orderId %></code></p>
    <p><strong>SWIFT:</strong> <%= process.env.FNB_SWIFT %></p>
  </div>
  <a href="/" class="btn btn-primary">Continue Shopping</a>
</div>

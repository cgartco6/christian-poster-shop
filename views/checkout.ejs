<!-- views/checkout.ejs -->
<div class="container">
    <h1>Checkout</h1>
    
    <form action="/payment/process" method="POST" id="checkout-form">
        <div class="checkout-form">
            <h3>Your Details</h3>
            <div class="form-group">
                <label>Full Name *</label>
                <input type="text" name="name" id="name" required>
            </div>
            <div class="form-group">
                <label>Email *</label>
                <input type="email" name="email" id="email" required>
            </div>
            <div class="form-group">
                <label>Phone</label>
                <input type="tel" name="phone" id="phone">
            </div>
            <div class="form-group">
                <label>Delivery Address *</label>
                <textarea name="address" id="address" rows="3" required></textarea>
            </div>
            
            <h3>Payment Method</h3>
            <div class="payment-methods">
                <div class="payment-method" data-method="payfast">
                    <strong>PayFast</strong><br>
                    <small>Credit/Debit Card, EFT</small>
                </div>
                <div class="payment-method" data-method="stripe">
                    <strong>Stripe</strong><br>
                    <small>Card Payments</small>
                </div>
                <div class="payment-method" data-method="paypal">
                    <strong>PayPal</strong><br>
                    <small>PayPal Account</small>
                </div>
                <div class="payment-method" data-method="eft">
                    <strong>Direct EFT</strong><br>
                    <small>Capitec Bank Transfer</small>
                </div>
            </div>
            <input type="hidden" name="paymentMethod" id="payment-method-input" required>
            
            <div class="order-summary" style="margin: 1rem 0; padding: 1rem; background: #f8f9fa; border-radius: 5px;">
                <h4>Order Summary</h4>
                <p>Items: <%= cart.totalItems %></p>
                <p>Total: <strong style="color: #e67e22;">R<%= cart.totalPrice %></strong></p>
            </div>
            
            <button type="submit" class="btn btn-primary" style="width: 100%;">Place Order & Pay</button>
        </div>
    </form>
</div>
